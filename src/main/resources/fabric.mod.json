{
	"schemaVersion": 1,
	"id": "horizontal-scrolling-fix",
	"version": "${version}",
	"name": "Horizontal Scrolling Fix",
	"description": "This client-side mod allows you to disable horizontal mouse scrolling (introduced in 1.20.2) entirely, or reverse its direction.",
	"authors": [
		{
			"name": "Flavien Dussud",
			"contact": {
				"homepage": "https://flavien.dussud.org",
				"modrinth": "https://modrinth.com/user/flavien",
				"twitter": "https://twitter.com/flaviendussud",
				"x": "https://x.com/flaviendussud"
			}
		}
	],
	"contact": {
		"email": "mods+horizontalscrollingfix@dussud.org",
		"sources": "https://github.com/dussud/horizontal-scrolling-fix",
		"issues": "https://github.com/dussud/horizontal-scrolling-fix/issues"
	},
	"license": "CC BY-SA 4.0",
	"icon": "assets/horizontal-scrolling-fix/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"org.dussud.horizontal_scrolling_fix.HorizontalScrollingFix"
		],
		"client": [
			"org.dussud.horizontal_scrolling_fix.client.HorizontalScrollingFixClient"
		],
		"ukulib": [
			"org.dussud.horizontal_scrolling_fix.client.UkulibIntegration"
		]
	},
	"mixins": [
		{
			"config": "horizontal-scrolling-fix.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"ukulib": "^1.10.2"
	}
}